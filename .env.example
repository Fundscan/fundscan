# Copy to .env and fill in. Never commit .env.
# Generate SECRET_KEY: openssl rand -hex 32

SECRET_KEY=change-me-32-bytes-hex
BASE_URL=https://fundscan.io
DB_PATH=/var/lib/fundscan/fundscan.db
FETCH_INTERVAL=60

# SMTP (for magic links) — Postmark recommended
SMTP_HOST=smtp.postmarkapp.com
SMTP_PORT=587
SMTP_USER=your-postmark-api-token
SMTP_PASS=your-postmark-api-token
FROM_EMAIL=noreply@fundscan.io

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Telegram bot
TELEGRAM_BOT_TOKEN=
