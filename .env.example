# Copy to .env and fill in values. Never commit .env.
# Generate SECRET_KEY: openssl rand -hex 32

SECRET_KEY=change-me-32-bytes-hex
BASE_URL=https://fundscan.uk

# Railway: set DB_PATH=/data/fundscan.db (matches the volume mount in railway.toml)
# Local dev: leave as default (writes fundscan.db in project root)
DB_PATH=fundscan.db

FETCH_INTERVAL=60

# Email — choose ONE of the two options below:

# Option A: Resend (recommended — https://resend.com, free tier = 3k emails/month)
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@fundscan.uk

# Option B: SMTP (Gmail, Zoho, Postmark, etc.)
# Leave blank if using Resend above. Code tries Resend first, falls back to SMTP.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-smtp-password
# FROM_EMAIL is shared between both options (set it above)

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Telegram bot (optional — only needed for Telegram alerts)
TELEGRAM_BOT_TOKEN=

# KKB integration Phase 3 — shared token for GET /api/signals/kraken
# (X-FundScan-Token header). Leave unset to keep the endpoint 404'd/disabled.
# Generate: openssl rand -hex 32
FUNDSCAN_SIGNAL_TOKEN=

# Optional override of the default 3-pair KKB can trade (BTC/ETH/SOL GBP).
# JSON object matching fundscan/signals.py's _DEFAULT_TRADEABLE_PAIRS shape:
#   {"PF_XBTUSD": {"pair": "BTC/GBP", "suggested_capital_gbp": 1787.5}, ...}
KRAKEN_TRADEABLE_PAIRS=
